---
import Layout from '../layouts/Layout.astro';
---

<Layout title="חברות בקהילה - ראשית דגנך">
  <main class="max-w-[1100px] mx-auto px-8 py-12">
    <h1 class="text-3xl font-bold mb-6">חברות בקהילה</h1>
    
    <div class="bg-surface p-8 border border-border">
      <p class="text-text-muted leading-relaxed mb-8">
        הצטרפו למשפחת ראשית דגנך! חברות בקהילה מעניקה תחושת שייכות ותורמת לקיום הפעילות השוטפת.
      </p>
      
      <h2 class="text-xl font-bold text-text mb-4">הטבות לחברי הקהילה</h2>
      <ul class="list-disc list-inside text-text-muted space-y-2 mb-8">
        <li>מקום קבוע בבית הכנסת</li>
        <li>הנחה בהשכרת האולם</li>
        <li>עדכונים שוטפים על אירועים</li>
        <li>השתתפות באסיפות הקהילה</li>
      </ul>
      
      <h2 class="text-xl font-bold text-text mb-4">דמי חברות</h2>
      <p class="text-text-muted mb-8">
        דמי החברות השנתיים: ₪XXX למשפחה
      </p>
      
      <a href={`${import.meta.env.BASE_URL}contact`} class="btn btn-primary inline-block">להצטרפות</a>
    </div>
  </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="תרומות - ראשית דגנך">
  <main class="max-w-[1100px] mx-auto px-8 py-12">
    <h1 class="text-3xl font-bold mb-6">תרומות</h1>
    
    <div class="bg-surface p-8 border border-border">
      <p class="text-text-muted leading-relaxed mb-8">
        תרומתכם מסייעת לנו להמשיך לקיים את פעילות בית הכנסת, לתחזק את המבנה ולארגן אירועים לקהילה.
      </p>
      
      <h2 class="text-xl font-bold text-text mb-4">דרכי תרומה</h2>
      
      <div class="space-y-4">
        <div class="p-4 bg-background border border-border-light">
          <h3 class="font-semibold mb-2">העברה בנקאית</h3>
          <p class="text-sm text-text-muted">בנק: [שם הבנק]<br/>סניף: [מספר סניף]<br/>חשבון: [מספר חשבון]</p>
        </div>
        
        <div class="p-4 bg-background border border-border-light">
          <h3 class="font-semibold mb-2">Bit / PayBox</h3>
          <p class="text-sm text-text-muted">054-1234567</p>
        </div>
        
        <div class="p-4 bg-background border border-border-light">
          <h3 class="font-semibold mb-2">PayPal</h3>
          <p class="text-sm text-text-muted">
            <a href="#" class="text-primary hover:underline">לתרומה דרך PayPal</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
